    <worksheet name='Sales by Year'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Yearly Pharmaceutical Sales Trend
</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Business Question</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>How have pharmaceutical sales changed over the years?</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Insight</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Sales fluctuate across the six-year period, indicating changing market demand and seasonal business cycles. Monitoring yearly trends helps management forecast demand, allocate budgets, and identify long-term growth or decline.</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='pharma_cleaned' name='federated.1ecjdlm0m6682211111o90phg1r0' />
